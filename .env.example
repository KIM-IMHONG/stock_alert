# 한국투자증권 OpenAPI 설정
# KIS Developers (https://developers.koreainvestment.com) 에서 발급받은 정보

# API 키 (앱키)
KIS_APP_KEY=your_app_key_here

# API 시크릿 (앱시크릿)
KIS_APP_SECRET=your_app_secret_here

# 계좌 정보 (선택사항, 매매 기능 사용시 필요)
KIS_ACCOUNT_NO=your_account_number
KIS_ACCOUNT_PREFIX=50

# 텔레그램 봇 설정 (알림 발송용)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# 로그 설정
LOG_LEVEL=INFO
LOG_FILE=logs/stock_alert.log

# 모니터링 설정
MONITORING_INTERVAL=30
SURGE_THRESHOLD=5.0
PLUNGE_THRESHOLD=-5.0

# 모니터링 종목 (쉼표로 구분)
WATCH_LIST=005930,000660,035420,051910